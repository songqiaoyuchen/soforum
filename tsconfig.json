{
    "compilerOptions": {
      "target": "ES6",
      "lib": ["dom", "esnext"],
      "jsx": "react-jsx",
      "types": ["react", "react-dom"],
      "moduleResolution": "node",
      "strict": true,
      "noImplicitAny": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "rootDir": "src"
    },
    "include": [
      "src/**/*"
    ]
  }